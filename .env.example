# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

# ============================================================
# NOTIFICATION SETTINGS
# You can enable one or both notification methods
# ============================================================

# Telegram Bot Configuration (Optional)
# Get token from @BotFather on Telegram
# Get chat ID from @userinfobot or @getmyid_bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id_from_userinfobot

# Discord Webhook Configuration (Optional)
# Get from Discord: Server Settings → Integrations → Webhooks → New Webhook
# Copy the webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ============================================================
# ADVANCED SETTINGS (Optional)
# ============================================================

# Store known companies as environment variable (for stateless deployment)
# KNOWN_COMPANIES={}